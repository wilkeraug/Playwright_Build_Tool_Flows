# Authentication credentials
AUTH_USERNAME=your-username-or-email
AUTH_PASSWORD=your-password
AUTH_LOGIN_URL=https://your-app.com/login
AUTH_OIDC_URL_PATTERN=**/login-idp**
AUTH_STORAGE_STATE_PATH=.auth/state.json
# URL to navigate to for session validation (should be behind auth)
AUTH_POST_LOGIN_URL=https://your-app.com/members/homepage
# URL fragment that indicates the session has expired and you're on the login page
AUTH_LOGIN_URL_FRAGMENT=/login

# Optional environment overrides

# Set to 'false' to run browser in headed (visible) mode
PWHEADLESS=true

# Override extraction timeout in milliseconds (default: 30000)
# EXTRACTION_TIMEOUT=30000

# Override default viewport width
# VIEWPORT_WIDTH=1280

# Override default viewport height
# VIEWPORT_HEIGHT=720
